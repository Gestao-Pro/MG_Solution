# Client (Vite)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
VITE_STRIPE_PRICE_STARTER=price_XXXXXXXXXXXXXXXX
VITE_STRIPE_PRICE_PRO=price_YYYYYYYYYYYYYYYY
VITE_STRIPE_PRICE_PREMIUM=price_ZZZZZZZZZZZZZZZZ
VITE_STRIPE_PRICE_STARTER_YEARLY=price_AAAAAAAAAAAAAAAA
VITE_STRIPE_PRICE_PRO_YEARLY=price_BBBBBBBBBBBBBBBB
VITE_STRIPE_PRICE_PREMIUM_YEARLY=price_CCCCCCCCCCCCCCCC

# Optional daily limits (used by Header/Billing usage display)
VITE_CHAT_DAILY_LIMIT_FREE=50
VITE_CHAT_DAILY_LIMIT_STARTER=200
VITE_CHAT_DAILY_LIMIT_PRO=500
VITE_CHAT_DAILY_LIMIT_PREMIUM=1000
VITE_TTS_DAILY_LIMIT_FREE=50
VITE_TTS_DAILY_LIMIT_STARTER=200
VITE_TTS_DAILY_LIMIT_PRO=500
VITE_TTS_DAILY_LIMIT_PREMIUM=1000

# Server (Express)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
CLIENT_URL=http://localhost:3002
PORT=4001 # usado apenas em desenvolvimento local
AUTH_JWT_SECRET=change_this_in_production

# Database (Supabase)
# Use a string oficial do Supabase (Project Settings → Database), com sslmode=require
# Exemplo: postgresql://postgres:password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Stripe Price IDs (produção)
STRIPE_PRICE_STARTER=price_XXXXXXXXXXXXXXXX
STRIPE_PRICE_PRO=price_YYYYYYYYYYYYYYYY
STRIPE_PRICE_PREMIUM=price_ZZZZZZZZZZZZZZZZ
STRIPE_PRICE_STARTER_YEARLY=price_AAAAAAAAAAAAAAAA
STRIPE_PRICE_PRO_YEARLY=price_BBBBBBBBBBBBBBBB
STRIPE_PRICE_PREMIUM_YEARLY=price_CCCCCCCCCCCCCCCC

# Produção (Vercel)
# Em produção, defina CLIENT_URL para o domínio do frontend (por ex.: https://seu-app.vercel.app)
# Variáveis devem ser configuradas no projeto Vercel (Production/Preview) e não em arquivos .env
# CLIENT_URL=https://seu-app.vercel.app